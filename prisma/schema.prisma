// E-commerce product images — Prisma schema (Phase 0 scaffold)
//
// Tables cover: auth (User/Account/Session via NextAuth), credit ledger,
// payment orders, image-generation jobs, and the resulting images.
// Field comments describe intent; nothing here is final — adjust as features land.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth-compatible) ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  image         String?
  emailVerified DateTime?
  /** When the user accepted the TOS + privacy policy on signup. */
  termsAgreedAt DateTime?
  credits       Int       @default(0) // current spendable balance
  /** Shareable invitation code. Stable, indexed for ?ref= lookup. */
  referralCode  String    @unique @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  jobs            Job[]
  orders          Order[]
  creditEntries   CreditEntry[]
  /** People this user has successfully referred. */
  referralsSent     Referral[] @relation("Referrer")
  /** The single Referral row where this user was the invitee, if any. */
  referralReceived  Referral?  @relation("Invitee")
}

// ─── Email verification (register / future password reset) ───────────────────
// Holds short-lived one-time codes. The code is bcrypt-hashed so a DB leak
// doesn't expose live codes. We keep a separate row per code request so we
// can observe rate-limit history (instead of overwriting).

enum EmailVerificationPurpose {
  REGISTER
  PASSWORD_RESET
  EMAIL_CHANGE
}

model EmailVerification {
  id          String                   @id @default(cuid())
  email       String
  purpose     EmailVerificationPurpose @default(REGISTER)
  codeHash    String                   // bcrypt(code)
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int                      @default(0) // failed verify attempts
  ip          String?
  createdAt   DateTime                 @default(now())

  @@index([email, createdAt])
  @@index([expiresAt])
}

// ─── Admin (independent auth, separate from User) ────────────────────────────
// Admins log in through a dedicated /admin/login flow with their own session
// cookie. There is no relation to User — preventing accidental privilege
// escalation if a User session is ever leaked.

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Referral / invitations ──────────────────────────────────────────────────
// A row is created the moment an invited user successfully registers via a
// `ref` code. Both sides receive credits as a side-effect inside the same
// transaction. `inviteeId` is unique → enforces "one user can only be invited
// once". Rejected attempts (same IP, disposable email, etc) never reach this
// table; they short-circuit at the register endpoint.

enum ReferralStatus {
  GRANTED
  REVOKED // reserved for admin / manual fraud action
}

model Referral {
  id          String         @id @default(cuid())
  referrerId  String
  inviteeId   String         @unique
  status      ReferralStatus @default(GRANTED)
  /** Credits granted to each party at signup time, snapshotted. */
  referrerReward Int
  inviteeReward  Int
  /** Snapshot of the invitee's signup IP — for audits. */
  inviteeIp   String?
  /** Snapshot of the invitee's device fingerprint hash. */
  inviteeFp   String?
  createdAt   DateTime       @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  invitee  User @relation("Invitee",  fields: [inviteeId],  references: [id], onDelete: Cascade)

  @@index([referrerId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Credit ledger ───────────────────────────────────────────────────────────
// Every credit movement (purchase, spend, refund) is recorded immutably so we
// can audit balance vs. ledger sum.

enum CreditEntryType {
  PURCHASE
  SPEND
  REFUND
  ADMIN_ADJUST
}

model CreditEntry {
  id        String          @id @default(cuid())
  userId    String
  amount    Int             // positive for credit, negative for debit
  type      CreditEntryType
  jobId     String?         // links spend/refund to a Job
  orderId   String?         // links purchase to an Order
  note      String?
  createdAt DateTime        @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  job   Job?   @relation(fields: [jobId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId, createdAt])
}

// ─── Payment orders ──────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  WECHAT
  ALIPAY
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  provider        PaymentProvider
  providerOrderId String?         @unique // ID from wechat/alipay
  amountCents     Int             // RMB cents
  credits         Int             // credits to grant on success
  status          OrderStatus     @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditEntries CreditEntry[]

  @@index([userId, status])
}

// ─── Generation jobs & images ────────────────────────────────────────────────

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum ImageKind {
  SOURCE     // user-uploaded product photo
  GENERATED  // model output
}

model Job {
  id           String    @id @default(cuid())
  userId       String
  status       JobStatus @default(PENDING)
  // Free-form snapshot of user inputs (product title, highlights, style, etc.)
  inputJson    Json
  // Snapshot of the prompt plan derived from inputJson (one prompt per panel)
  promptPlan   Json?
  creditsCost  Int       @default(0)
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images        Image[]
  creditEntries CreditEntry[]

  @@index([userId, createdAt])
}

model Image {
  id        String    @id @default(cuid())
  jobId     String
  kind      ImageKind
  // Identifier of the panel this image corresponds to (e.g. "hero", "feature-1")
  panel     String?
  ossKey    String    // object-storage key (e.g. uploads/.../foo.png)
  url       String?   // optional CDN URL cached for convenience
  width     Int?
  height    Int?
  bytes     Int?
  mimeType  String?
  createdAt DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}
