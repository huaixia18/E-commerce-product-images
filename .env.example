# Copy this file to .env.local for development, or .env in production.
# NEVER commit a populated .env — it is gitignored.

# ─── Database (matches docker-compose.yml) ────────────────────────────────────
DATABASE_URL="postgresql://ecom:ecom@localhost:5432/ecom?schema=public"

# ─── Redis (BullMQ queue) ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── GPT-Image-2 via BananaRouter ─────────────────────────────────────────────
# OpenAI-SDK compatible. Get a fresh key from https://bananarouter.com after
# revoking any previously-leaked one.
BANANAROUTER_API_KEY=""
BANANAROUTER_BASE_URL="https://api.bananarouter.com/v1"
BANANAROUTER_MODEL="gpt-image-2"

# ─── Aliyun OSS ───────────────────────────────────────────────────────────────
# Use a RAM user scoped to ONLY this bucket (read/write), not a root key.
ALIYUN_OSS_REGION="oss-cn-hangzhou"
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
# Optional custom CDN/endpoint; leave blank to use the default OSS endpoint.
ALIYUN_OSS_ENDPOINT=""

# ─── Email service (registration verification codes) ─────────────────────────
# console (default): codes are printed to the server log. Use in dev.
# aliyun: send via Aliyun DirectMail (requires verified sender domain).
EMAIL_PROVIDER="console"
# Only set when EMAIL_PROVIDER=aliyun:
ALIYUN_DM_REGION="cn-hangzhou"
ALIYUN_DM_ACCESS_KEY_ID=""
ALIYUN_DM_ACCESS_KEY_SECRET=""
ALIYUN_DM_FROM_ADDRESS=""
ALIYUN_DM_FROM_ALIAS="图作AI"

# ─── Admin backoffice ─────────────────────────────────────────────────────────
# Optional separate secret for /admin sessions. Falls back to AUTH_SECRET.
ADMIN_SESSION_SECRET=""

# ─── Error monitoring (Sentry) ────────────────────────────────────────────────
# Leave blank for local dev — the SDK stays silent and makes no network calls.
# Point these at your self-hosted Sentry instance once it's running.
#   SENTRY_DSN             server + worker DSN (project ingest URL)
#   NEXT_PUBLIC_SENTRY_DSN browser DSN (can be the same project DSN)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Build-time source-map upload (optional — only for readable prod stack
# traces). Leave blank to skip upload entirely.
SENTRY_URL=""           # e.g. https://sentry.your-domain.com
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ─── Local dev only ───────────────────────────────────────────────────────────
# Set to "1" to bypass gpt-image-2 and OSS; the worker writes a stub PNG to
# tmp/ and embeds a data URL on the Image row so /api/jobs/[id] returns
# previewable images. Useful for smoke-testing the queue end-to-end.
STUB_IMAGE_MODEL=""

# ─── Payment ──────────────────────────────────────────────────────────────────
# mock (default): the pricing dialog shows a fake QR + a "我已付款（模拟）"
#   button that instantly settles the order. No real money.
# real: route wechat orders through WeChat Pay Native, alipay orders through
#   Alipay 当面付. Requires the credentials below + public callback URLs.
PAYMENT_PROVIDER="mock"

# WeChat Pay (微信支付) — API v3. From pay.weixin.qq.com 商户平台.
#   APP_ID:        关联的公众号/小程序/APP appid
#   MCH_ID:        商户号
#   API_V3_KEY:    APIv3 密钥（32 字节）— 用于回调解密
#   SERIAL_NO:     商户 API 证书序列号
#   PRIVATE_KEY:   商户 API 私钥 PEM（用 \n 表示换行写成单行）
#   PLATFORM_CERT: 微信支付平台证书公钥 PEM（用 \n 表示换行）
# 回调地址配置为：<AUTH_URL>/api/payments/notify/wechat
WECHAT_PAY_APP_ID=""
WECHAT_PAY_MCH_ID=""
WECHAT_PAY_API_V3_KEY=""
WECHAT_PAY_SERIAL_NO=""
WECHAT_PAY_PRIVATE_KEY=""
WECHAT_PAY_PLATFORM_CERT=""

# Alipay 当面付 — OpenAPI. From open.alipay.com.
#   APP_ID:       应用 ID
#   PRIVATE_KEY:  应用私钥 PEM（用 \n 表示换行）
#   PUBLIC_KEY:   支付宝公钥 PEM（用 \n 表示换行）— 用于回调验签
#   GATEWAY:      可选，默认 https://openapi.alipay.com/gateway.do
# 回调地址配置为：<AUTH_URL>/api/payments/notify/alipay
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_GATEWAY=""
