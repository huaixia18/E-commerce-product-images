{
  "name": "ecom-detail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma": "dotenv -e .env.local -- prisma",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
