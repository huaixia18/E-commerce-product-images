    "db:studio": "dotenv -e .env.local -- prisma studio",
    "worker": "dotenv -e .env.local -- tsx watch src/worker.ts",
    "worker:start": "dotenv -e .env.local -- tsx src/worker.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.16.2",
    "ali-oss": "^6.23.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.10",
    "ioredis": "^5.10.1",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "openai": "^6.38.0",
    "prisma": "^6.16.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/ali-oss": "^6.23.3",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
